# Required -- server will fail to start without these
BC_BASE_URL=http://Cronus27/BC
BC_USERNAME=
BC_PASSWORD=

# Optional
BC_TENANT_ID=default
BC_CLIENT_VERSION=27.0.0.0
# navigationContext.applicationId sent in OpenSession. BC 27 (ltsc2025) expects
# "NAV" (the default); "FIN" makes the server throw NavCancelCredentialPromptException
# on OpenSession even though HTTP auth and the WS handshake succeed. Override only
# if a different BC build expects another value.
BC_APPLICATION_ID=NAV
# BC profile id (e.g. "BUSINESS MANAGER"). Server uppercases and trims;
# unknown id silently falls back to user default. Empty = server default.
# Affects which Role Center loads and which pages Tell Me indexes.
# BC_PROFILE=
PORT=3000
LOG_LEVEL=info
LOG_DIR=./logs
STATE_DIR=./.state
